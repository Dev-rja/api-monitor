[0m11:10:23.667312 [debug] [Thread-1 (]: On model.api_monitor.stg_pings: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "api_monitor", "target_name": "dev", "node_id": "model.api_monitor.stg_pings"} */

    
    create view main."stg_pings" as
    

with source as (

    select * from raw."raw_pings"

),

cleaned as (

    select
        -- identifiers
        id                                          as ping_id,
        api_name,
        url,

        -- timing
        datetime(checked_at)                        as checked_at,
        cast(strftime('%H', checked_at) as integer) as hour_of_day,
        strftime('%Y-%m-%d', checked_at)            as check_date,

        -- response details
        status_code,
        cast(response_ms as real)                   as response_ms,
        cast(sla_ms as real)                        as sla_ms,

        -- booleans (stored as 0/1 in SQLite)
        cast(is_success as integer)                 as is_success,
        case
            when is_success = 0 then 1
            else 0
        end                                         as is_failure,

        -- SLA breach: success but too slow, OR outright failure
        case
            when response_ms > sla_ms then 1
            else 0
        end                                         as breached_sla,

        -- how far over/under the SLA threshold (negative = within SLA)
        round(response_ms - sla_ms, 2)             as sla_delta_ms,

        -- error handling
        error_message,
        case
            when error_message = 'timeout'              then 'timeout'
            when error_message like 'request_error:%'   then 'network_error'
            when is_success = 0 and error_message is null then 'wrong_status'
            else null
        end                                         as failure_reason

    from source

)

select * from cleaned;
